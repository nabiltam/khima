rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: customers
    // Document ID: customerId
    // Fields:
    //   - id: string (required)
    //   - name: string (required)
    //   - phone: string (required)
    //   - lastBookingDate: string (optional)
    //
    // Collection: bookings
    // Document ID: bookingId
    // Fields:
    //   - id: string (required)
    //   - tentId: string (required)
    //   - tentSize: string (required)
    //   - location: string (required)
    //   - customerId: string (required)
    //   - customerName: string (required)
    //   - customerPhone: string (required)
    //   - totalPrice: number (required)
    //   - deposit: number (required)
    //   - remaining: number (required)
    //   - startDate: string (required)
    //   - endDate: string (required)
    //   - pickupTime: string (required)
    //   - status: string (required)
    //   - reminder24hSent: bool (optional)
    //   - reminder1hSent: bool (optional)
    //   - createdAt: string (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "tamnabil99@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidCustomer(data) {
      return data.id is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.phone is string && data.phone.size() > 0 && data.phone.size() < 20;
    }

    function isValidBooking(data) {
      return data.id is string &&
             data.tentId is string &&
             data.tentSize in ["12/12", "9/12", "9/9", "12/15"] &&
             data.location is string &&
             data.customerId is string &&
             data.customerName is string &&
             data.customerPhone is string &&
             data.totalPrice is number &&
             data.deposit is number &&
             data.remaining is number &&
             data.startDate is string &&
             data.endDate is string &&
             data.pickupTime is string &&
             data.status in ["active", "completed", "cancelled"] &&
             data.createdAt is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    match /customers/{customerId} {
      allow read, write: if isAuthenticated();
    }

    match /bookings/{bookingId} {
      allow read, write: if isAuthenticated();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
